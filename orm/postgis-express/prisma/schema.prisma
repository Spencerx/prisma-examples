generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Location {
  id       Int                                  @id @default(autoincrement())
  name     String
  location Unsupported("\"public\".geography")?
}

model User {
  id       Int                                  @id @default(autoincrement())
  name     String
  location Unsupported("\"public\".geography")?
}
